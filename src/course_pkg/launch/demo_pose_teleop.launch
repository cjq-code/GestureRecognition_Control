<?xml version="1.0"?>
<!--
  体感识别控制 course_pkg 小车（Gazebo）一键启动

  终端1: roscore（若尚未运行）
  终端2: roslaunch course_pkg demo_pose_teleop.launch

  说明:
  - 场景: worlds/pose_course.world — 无房顶家居房间（四壁 + 桌椅柜 + 地面可动物品 + 绿色归位标记）
  - 体感: handcontrol 的 body_pose_estimation + teleop_mapper → /cmd_vel
  - 轮距与 URDF 中 wheelSeparation 一致（base_link 直径 0.2 m）
  - 后续可换带机械臂的移动平台 URDF：对零碎物体做抓取并摆回绿色「归位区」；需在 URDF/Gazebo 中加臂与 gripper 插件
-->
<launch>
  <arg name="world" default="$(find course_pkg)/worlds/pose_course.world"/>
  <!-- 出生点在房间内靠南侧空地，避开家具与杂物 -->
  <arg name="spawn_x" default="-2.6"/>
  <arg name="spawn_y" default="-2.4"/>
  <arg name="spawn_z" default="0.05"/>
  <arg name="camera_index" default="0"/>
  <arg name="use_ros_topic" default="false"/>
  <arg name="image_topic" default="/camera/image_raw"/>
  <arg name="show_debug" default="true"/>
  <!-- 小车尺寸较小，速度保守，便于仿真稳定 -->
  <arg name="max_linear_speed" default="0.35"/>
  <arg name="max_angular_speed" default="1.4"/>

  <param name="use_sim_time" value="true"/>

  <!-- pose_course.world 中 model:// 依赖本地模型目录 -->
  <env name="GAZEBO_MODEL_PATH"
       value="$(find course_pkg)/gazebo_models:$(optenv GAZEBO_MODEL_PATH)"/>

  <param name="robot_description"
         command="$(find xacro)/xacro $(find course_pkg)/urdf/xacro/my_car_camera.urdf.xacro"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="recording" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_mycar"
        args="-urdf -model mycar -param robot_description
              -x $(arg spawn_x) -y $(arg spawn_y) -z $(arg spawn_z)"/>

  <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher"/>
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>

  <include file="$(find handcontrol)/launch/handcontrol.launch">
    <arg name="camera_index" value="$(arg camera_index)"/>
    <arg name="use_ros_topic" value="$(arg use_ros_topic)"/>
    <arg name="image_topic" value="$(arg image_topic)"/>
    <arg name="show_debug" value="$(arg show_debug)"/>
    <arg name="max_linear_speed" value="$(arg max_linear_speed)"/>
    <arg name="max_angular_speed" value="$(arg max_angular_speed)"/>
    <!-- 与 course_pkg/urdf/xacro/move.urdf.xacro 中 wheelSeparation = 2*base_link_radius 一致 -->
    <arg name="wheel_base" value="0.2"/>
  </include>
</launch>
