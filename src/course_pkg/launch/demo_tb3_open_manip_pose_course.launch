<?xml version="1.0"?>
<!--
  TurtleBot3 Waffle Pi + OpenMANIPULATOR-X 仿真 + course_pkg 家居场景 + 体感底盘遥控

  依赖（已放入 src 并从源码编译）:
    turtlebot3, turtlebot3_msgs, turtlebot3_manipulation（仅 description）,
    turtlebot3_manipulation_simulations（gazebo）

  说明:
    - 为免系统未装 MoveIt，turtlebot3_manipulation 中带 moveit_msgs 等依赖的子包已加 CATKIN_IGNORE；
      若已 apt 安装 ros-noetic-moveit*，可自行删掉对应 CATKIN_IGNORE 以启用 MoveIt/GUI/导航 等包。
    - 机械臂关节控制: Gazebo 内已加载 arm_controller / gripper_controller，可用 rqt 或 trajectory_msgs 发送轨迹。
    - 场景尺度: 桌面约 0.8 m，地面杂物约 1～20 cm；机器人 URDF 均匀缩放（默认 1.92）使整机高度接近约 1 m。
    - 底盘: teleop_mapper 发布 /cmd_vel_body，course_pkg/cmd_vel_scan_avoid 融合激光后发布 /cmd_vel。
    - wheel_base 应与缩放后 URDF 中 wheelSeparation 一致（默认 0.287*1.92）。

  用法:
    source /opt/ros/noetic/setup.bash && source ~/catkin_ws/devel/setup.bash
    export TURTLEBOT3_MODEL=waffle_pi   # launch 内已设置，可省略
    roslaunch course_pkg demo_tb3_open_manip_pose_course.launch
    # 摄像头: rosrun handcontrol list_usb_cameras.py 查看可用 index；自动选第一个可用设备:
    # roslaunch course_pkg demo_tb3_open_manip_pose_course.launch camera_index:=-1
-->
<launch>
  <arg name="world" default="$(find course_pkg)/worlds/pose_course.world"/>
  <arg name="spawn_x" default="-2.6"/>
  <arg name="spawn_y" default="-2.4"/>
  <arg name="spawn_z" default="0.01"/>
  <arg name="spawn_yaw" default="0.0"/>
  <arg name="paused" default="false"/>
  <arg name="gui" default="true"/>
  <arg name="camera_index" default="0"/>
  <arg name="use_ros_topic" default="false"/>
  <arg name="image_topic" default="/camera/image_raw"/>
  <arg name="show_debug" default="true"/>
  <arg name="max_linear_speed" default="0.22"/>
  <arg name="max_angular_speed" default="1.0"/>
  <arg name="use_handcontrol" default="true"/>
  <arg name="use_course_mapping" default="true"/>
  <!-- 均匀缩放 URDF，使小车+机械臂约 1 m 级；与 teleop wheel_base 一致 -->
  <arg name="robot_scale" default="1.92"/>
  <arg name="wheel_base" default="0.551"/>

  <env name="TURTLEBOT3_MODEL" value="waffle_pi"/>
  <env name="GAZEBO_MODEL_PATH" value="$(find course_pkg)/gazebo_models:$(optenv GAZEBO_MODEL_PATH)"/>

  <param name="use_sim_time" value="true"/>

  <rosparam file="$(find turtlebot3_manipulation_gazebo)/config/gazebo_controller.yaml" command="load"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="use_sim_time" value="true"/>
  </include>

  <param name="robot_description"
         command="$(find course_pkg)/scripts/gen_scaled_robot_description.sh $(arg robot_scale)"/>

  <node name="spawn_tb3_manipulation" pkg="gazebo_ros" type="spawn_model" respawn="false" output="screen"
        args="-urdf -param robot_description -model turtlebot3_with_open_manipulator
              -x $(arg spawn_x) -y $(arg spawn_y) -z $(arg spawn_z) -Y $(arg spawn_yaw)
              -J joint1 0.0 -J joint2 0.0 -J joint3 0.0 -J joint4 0.0 -J gripper 0.0 -J gripper_sub 0.0"/>

  <include file="$(find turtlebot3_manipulation_gazebo)/launch/controller_utils.launch"/>
  <include file="$(find turtlebot3_manipulation_gazebo)/launch/turtlebot3_manipulation_controller.launch"/>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen"/>

  <group if="$(arg use_handcontrol)">
    <include file="$(find handcontrol)/launch/handcontrol.launch">
      <arg name="camera_index" value="$(arg camera_index)"/>
      <arg name="use_ros_topic" value="$(arg use_ros_topic)"/>
      <arg name="image_topic" value="$(arg image_topic)"/>
      <arg name="show_debug" value="$(arg show_debug)"/>
      <arg name="max_linear_speed" value="$(arg max_linear_speed)"/>
      <arg name="max_angular_speed" value="$(arg max_angular_speed)"/>
      <arg name="wheel_base" value="$(arg wheel_base)"/>
      <arg name="use_course_mapping" value="$(arg use_course_mapping)"/>
    </include>
  </group>

  <node pkg="course_pkg" type="cmd_vel_scan_avoid.py" name="cmd_vel_scan_avoid" output="screen">
    <param name="cmd_vel_in" value="/cmd_vel_body"/>
    <param name="cmd_vel_out" value="/cmd_vel"/>
    <param name="scan_topic" value="/scan"/>
    <param name="armed_topic" value="/course_base_armed"/>
  </node>
</launch>
